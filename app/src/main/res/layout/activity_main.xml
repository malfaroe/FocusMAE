<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FOCUS MAE"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- ══ TABATA ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/section_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TABATA"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="14dp"/>

            <!-- Config (visible when idle) -->
            <LinearLayout
                android:id="@+id/configSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <!-- Work row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Trabajo"
                        android:textColor="@color/work"
                        android:textSize="15sp"/>
                    <Button
                        android:id="@+id/btnWorkMinus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="-"
                        android:textSize="20sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <TextView
                        android:id="@+id/tvWorkVal"
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="5"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <Button
                        android:id="@+id/btnWorkPlus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="+"
                        android:textSize="20sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="min"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- Rest row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Descanso"
                        android:textColor="@color/rest"
                        android:textSize="15sp"/>
                    <Button
                        android:id="@+id/btnRestMinus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="-"
                        android:textSize="20sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <TextView
                        android:id="@+id/tvRestVal"
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <Button
                        android:id="@+id/btnRestPlus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="+"
                        android:textSize="20sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="min"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- Cycles row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ciclos"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"/>
                    <Button
                        android:id="@+id/btnCycMinus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="-"
                        android:textSize="20sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <TextView
                        android:id="@+id/tvCyclesVal"
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="5"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <Button
                        android:id="@+id/btnCycPlus"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="+"
                        android:textSize="20sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Running (visible when active) -->
            <LinearLayout
                android:id="@+id/runningSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvPhase"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRABAJO"
                    android:textColor="@color/work"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/work"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvCycle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ciclo 1 / 5"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnTabata"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="INICIAR"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="@color/btn_start"/>
        </LinearLayout>

        <!-- ══ METRONOME ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/section_bg"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="METRÓNOMO"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="12dp"/>

            <!-- BPM row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/btnBpmMinus"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="−"
                    android:textSize="28sp"
                    android:textColor="@color/bpm"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <TextView
                    android:id="@+id/tvBpm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="120"
                    android:textColor="@color/bpm"
                    android:textSize="72sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

                <Button
                    android:id="@+id/btnBpmPlus"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="+"
                    android:textSize="28sp"
                    android:textColor="@color/bpm"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="BPM"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnMetro"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="INICIAR"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="@color/btn_start"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
